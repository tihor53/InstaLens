# Instagram App Configuration
INSTAGRAM_APP_ID=your_app_id_here
INSTAGRAM_APP_SECRET=your_app_secret_here
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/auth/instagram/callback

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Groq API Configuration (REQUIRED for Mastra AI agents)
# Mastra agents use Groq's Llama 3.3 70B model (blazing fast & open source)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key-here

# Apify Configuration (REQUIRED for Instagram scraping)
APIFY_API_TOKEN=your_apify_api_token_here
APIFY_ACTOR_ID=your_apify_actor_id_here
APIFY_DATASET_ID=your_apify_dataset_id_here
