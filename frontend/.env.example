# Backend API Configuration
BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Redis Cache (Upstash) - Optional
UPSTASH_REDIS_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_TOKEN=your_redis_token_here

# Groq API Configuration (REQUIRED for Mastra AI agents on backend)
# Get your API key from: https://console.groq.com/keys
# NOTE: Backend processes this, frontend just needs it accessible to backend
GROQ_API_KEY=gsk_your-groq-api-key-here

# Google Cloud (REQUIRED for Google Sheets integration)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_CREDENTIALS='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# HubSpot Integration (Optional)
HUBSPOT_ACCESS_TOKEN=pat-na1-your-access-token-here

# Mailchimp Integration (Optional)
MAILCHIMP_API_KEY=your-api-key-us1

# Salesforce Integration (Optional)
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com
SALESFORCE_CLIENT_ID=your_client_id
SALESFORCE_CLIENT_SECRET=your_client_secret
SALESFORCE_USERNAME=your-email@example.com
SALESFORCE_PASSWORD=your_password_here
SALESFORCE_ACCESS_TOKEN=your_access_token_here

# BigQuery (Optional)
NEXT_PUBLIC_BIGQUERY_PROJECT_ID=your-project-id
NEXT_PUBLIC_BIGQUERY_DATASET_ID=your-dataset-id

# Mailchimp (Optional)
NEXT_PUBLIC_MAILCHIMP_LIST_ID=your-list-id

# Salesforce (Optional)
NEXT_PUBLIC_SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com

# Default Spreadsheet (Optional)
DEFAULT_SPREADSHEET_ID=your_default_spreadsheet_id

